# ==========================================
# GDM Job Cars - Variáveis de Ambiente
# ==========================================

# Aplicação
PORT=5000
NODE_ENV=development

# Banco de Dados (Neon PostgreSQL)
DATABASE_URL=postgresql://usuario:senha@ep-xxxxx.neon.tech/jobcars?sslmode=require

# JWT - Tokens
JWT_SECRET=troque-este-segredo-em-producao-com-string-aleatoria-longa
JWT_REFRESH_SECRET=troque-este-segredo-refresh-em-producao
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# CORS: lista separada por virgula (ex.: http://localhost:5173,https://app.seudominio.com).
# Use * apenas em dev. Apps mobile (sem Origin) sao sempre aceitos.
CORS_ORIGIN=http://localhost:5173

# Rate Limit (req/min)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Rate Limit dedicado ao login (anti forca-bruta)
LOGIN_RATE_WINDOW_MS=900000
LOGIN_RATE_MAX=10

# ===== SMTP (e-mail de aprovacao/rejeicao/senha temporaria) =====
# Enquanto SMTP_HOST estiver vazio, o envio de e-mail fica DESATIVADO.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=GDM Job Cars <no-reply@seudominio.com>

